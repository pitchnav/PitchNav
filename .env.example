# =============================================================
# Pitch Nav Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — server-side only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Stripe ────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
# Use test keys (sk_test_...) for development.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Webhook secret — from: Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Two recurring monthly Stripe Prices. The legacy STRIPE_PRICE_ID is accepted
# only as a fallback for the $40 Complete Performance option.
STRIPE_PRODUCT_ID=prod_your-product-id
STRIPE_THROWING_PRICE_ID=price_your-25-monthly-price-id
STRIPE_PERFORMANCE_PRICE_ID=price_your-40-monthly-price-id

# ── Resend (transactional email) ──────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=Pitch Nav <noreply@yourdomain.com>

# ── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Pitch Nav

# Admin email addresses (comma-separated) that receive admin access
# These must also exist as Supabase auth users.
ADMIN_EMAILS=admin@yourdomain.com

# Where contact form submissions are forwarded (defaults to RESEND_FROM_EMAIL if unset)
CONTACT_DESTINATION_EMAIL=support@yourdomain.com

# ── Optional Analytics ────────────────────────────────────────
# Uncomment and fill in if you add analytics (e.g., Plausible, Umami)
# NEXT_PUBLIC_ANALYTICS_DOMAIN=yourdomain.com
# NEXT_PUBLIC_ANALYTICS_SRC=https://plausible.io/js/script.js

# Protects the scheduled retest-reminder endpoint. Generate a long random value.
CRON_SECRET=replace-with-a-long-random-secret

# Staff review inbox receives an approval email for each submitted analysis.
STAFF_REVIEW_EMAIL=pitchnavllc@gmail.com
# STRIPE_THROWING_PRICE_ID must be $25/month.
# STRIPE_PERFORMANCE_PRICE_ID must be $40/month.

# Server-only AI-assisted coaching drafts. Never prefix this with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MECHANICS_MODEL=gpt-5.4-mini

# Automatic calibrated side-view velocity worker. Keep both secrets server-only.
AUTO_VELOCITY_ENABLED=false
VIDEO_WORKER_URL=
VIDEO_WORKER_SECRET=
