{
  "expo": {
    "name": "Pitch Nav",
    "slug": "pitch-nav",
    "version": "1.0.0",
    "scheme": "pitchnav",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#020617",
    "ios": {
      "bundleIdentifier": "com.pitchnav.app",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Pitch Nav uses the camera so athletes can record side-view pitching videos for analysis.",
        "NSMicrophoneUsageDescription": "Pitch Nav uses the microphone when an athlete records a pitching video.",
        "NSPhotoLibraryUsageDescription": "Pitch Nav accesses the photo library so athletes can select pitching videos and radar images.",
        "NSPhotoLibraryAddUsageDescription": "Pitch Nav can save exported report images and motion videos to the photo library."
      }
    },
    "android": {
      "package": "com.pitchnav.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#020617",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#020617",
            "image": "./assets/splash-icon.png"
          }
        }
      ]
    ],
    "extra": {
      "webAppUrl": "https://pitch-nav.vercel.app"
    }
  }
}
